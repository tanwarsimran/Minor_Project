import cv2
from ultralytics import YOLO
import matplotlib.pyplot as plt   # ✅ added

# Load model
model = YOLO("yolov8n.pt")

# Load video
cap = cv2.VideoCapture("cars.mp4")

if not cap.isOpened():
    print("❌ Video not found - put cars.mp4 in same folder")
    exit()

print("✅ Running YOLO Detection...")

frame_counts = []   # ✅ store vehicle count

while True:
    ret, frame = cap.read()

    if not ret:
        break

    results = model(frame)

    count = 0   # ✅ count vehicles in this frame

    for r in results:
        for box in r.boxes:
            cls = int(box.cls[0])

            if cls in [2, 3, 5, 7]:  # vehicles
                count += 1   # ✅ increase count

                x1, y1, x2, y2 = map(int, box.xyxy[0])
                cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 255, 0), 2)

    frame_counts.append(count)   # ✅ store count

    cv2.imshow("Vehicle Detection", frame)

    if cv2.waitKey(1) == 27:
        break

cap.release()
cv2.destroyAllWindows()

# 📊 ✅ GRAPH (added at end only)
plt.plot(frame_counts)
plt.xlabel("Frame Number")
plt.ylabel("Number of Vehicles")
plt.title("Vehicle Detection Graph")

plt.show()
